APP_NAME=PredictaMaint
APP_VERSION=1.0.0
DEBUG=true

API_V1_STR=/api/v1

OPENAI_API_KEY=your_openai_api_key

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/predictamaint

LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=predictamaint

LSTM_MODEL_PATH=saved_models/lstm_model.h5
ISOLATION_FOREST_PATH=saved_models/isolation_forest.pkl
SCALER_PATH=saved_models/scaler.pkl

WEBSOCKET_INTERVAL_SECONDS=2

ALERT_NORMAL_THRESHOLD=0.3
ALERT_CRITICAL_THRESHOLD=0.7